 Phishing Analyzer - Environment Variables Configuration
# Copy this file to .env and fill in the actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Database URL - Choose one of the following:
# For SQLite (development only): sqlite:///phishing_analyzer.db
# For encrypted SQLite (recommended): sqlite+sqlcipher:///phishing_analyzer.db
# For PostgreSQL (production): postgresql://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://phishing_analyzer_db_user:I8w2vLnKWA5eeTSvaU2jcxut4B31avx5@dpg-d8t3hh36sc1c73e42bc0-a.oregon-postgres.render.com/phishing_analyzer_db

# Database encryption key (only required for SQLCipher)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Secret key for session management and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=74383c3e184067e76d76e745473e1db085f760a6439d364c7440af36be83d073

# Debug mode (set to False in production)
DEBUG=True

# API Tokens for authentication
# Format: token1,token2,token3
# For RBAC, append role with colon: token:role (e.g., abc123:admin)
# Roles: admin, analyst, user
# Example: abc123:admin,def456:analyst,ghi789:user
API_TOKENS=mytoken123:admin

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://gilded-trifle-133800.netlify.app,https://phishing-axis.onrender.com
DATABASE_URL=sqlite:///phishing_analyzer.db
DEBUG=True
MIN_SAMPLES=10
DATA_RETENTION_DAYS=90
PORT=5000


# ============================================
# SESSION CONFIGURATION
# ============================================
# Session cookie secure (set to True in production with HTTPS)
SESSION_COOKIE_SECURE=True

# ============================================
# DATA RETENTION CONFIGURATION
# ============================================
# Number of days to retain data before cleanup
DATA_RETENTION_DAYS=90

# ============================================
# ANOMALY DETECTION CONFIGURATION
# ============================================
# Sender surge multiplier (e.g., 5.0 = 5x normal volume)
SENDER_SURGE_MULTIPLIER=5.0

# Domain spike multiplier (e.g., 3.0 = 3x normal volume)
DOMAIN_SPIKE_MULTIPLIER=3.0

# Risk score spike threshold (e.g., 20 = sudden increase of 20 points)
RISK_SCORE_SPIKE=20

# Minimum samples before detecting anomalies
MIN_SAMPLES=10

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port to run the server on
PORT=5000
